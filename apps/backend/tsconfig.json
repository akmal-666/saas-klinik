{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "paths": {
      "@klinik/shared-types": [
        "../../packages/shared-types/src/index.ts"
      ],
      "@klinik/shared-types/*": [
        "../../packages/shared-types/src/*"
      ],
      "@klinik/shared-constants": [
        "../../packages/shared-constants/src/index.ts"
      ],
      "@klinik/shared-constants/*": [
        "../../packages/shared-constants/src/*"
      ],
      "rxjs": [
        "../../node_modules/rxjs"
      ],
      "rxjs/*": [
        "../../node_modules/rxjs/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts"
  ]
}
